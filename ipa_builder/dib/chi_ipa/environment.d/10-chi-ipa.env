# use zstd instead of gzip to compress ramdisk
export DIB_IPA_COMPRESS_CMD="zstd"

# patch `hardware` package to get interface speed/capacity/size from lshw
export DIB_IPA_HARDWARE_PACKAGE="git+https://github.com/ChameleonCloud/hardware.git"

# git ls-remote https://opendev.org/openstack/ironic-python-agent 'refs/tags/2023.1-eom^{}'
export DIB_REPOREF_ironic_python_agent=a488be6e21b036e13ea567ed334707ad09901d88
# git ls-remote https://opendev.org/openstack/requirements 'refs/tags/2023.1-eom^{}'
export DIB_REPOREF_requirements=838389db5a48e9bc6450e1ea51c4b36dd3d3f88f
